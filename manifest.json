{
  "manifest_version": 3,
  "name": "gmail-llm-gcal",
  "version": "1.0",
  "description": "GmailからLLM経由で予定を生成",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:11434/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
